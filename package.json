{
  "name": "untot-zombies",
  "version": "1.0.0",
  "description": "Ein richtig geiles Zombie Survival Spiel",
  "main": "app.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.untot.zombies",
    "productName": "UNTOT Zombies",
    "files": [
      "app.js",
      "index.html",
      "js/**/*",
      "data/**/*",
      "assets/**/*",
      "vendor/**/*"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "directories": {
      "output": "build"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
